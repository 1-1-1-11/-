{
  "name": "coffee-price-openclaw",
  "version": "0.1.0",
  "description": "OpenClaw WeChat coffee price helper for nearby delivery and pickup comparisons.",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json",
    "build": "tsc",
    "plugin:build": "npm run build && openclaw plugins build --entry ./dist/openclaw-plugin.js",
    "plugin:validate": "openclaw plugins validate --root . --entry ./dist/openclaw-plugin.js",
    "coffee": "tsx src/cli.ts",
    "capture": "tsx src/capture.ts",
    "capture:calibrate": "tsx src/capture-calibrate.ts",
    "config:scaffold": "tsx src/config-scaffold.ts",
    "config:set-url": "tsx src/config-set-url.ts",
    "doctor": "tsx src/doctor-cli.ts",
    "pricebook:refresh": "tsx src/pricebook-refresh-cli.ts",
    "meituan:app-source": "tsx src/meituan-app-source-cli.ts",
    "meituan:doctor": "tsx src/meituan-app-doctor-cli.ts",
    "meituan:serve": "tsx src/meituan-app-serve-cli.ts",
    "orderwise:mcp-source": "tsx src/orderwise-mcp-source-cli.ts",
    "orderwise:doctor": "tsx src/orderwise-mcp-doctor-cli.ts",
    "orderwise:serve": "tsx src/orderwise-mcp-serve-cli.ts",
    "luckin:doctor": "tsx src/luckin-mcp-doctor-cli.ts",
    "luckin:enable": "tsx src/luckin-mcp-enable-cli.ts",
    "luckin:import-token": "tsx src/luckin-token-import-cli.ts",
    "luckin:setup": "tsx src/luckin-setup-cli.ts",
    "luckin:mcp-source": "tsx src/luckin-mcp-source-cli.ts",
    "verify:next": "tsx src/live-next-action.ts",
    "verify:live": "tsx src/verify-live.ts",
    "weixin:login": "node --import ./scripts/openclaw-network-preload.mjs --import tsx src/weixin-login-cli.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cheerio": "^1.2.0",
    "playwright-core": "^1.61.0",
    "typebox": "^1.2.17",
    "undici": "^8.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "openclaw": "^2026.6.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.17"
  },
  "openclaw": {
    "extensions": [
      "./dist/openclaw-plugin.js"
    ]
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "config"
  ]
}
